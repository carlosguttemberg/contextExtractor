# Caminho para o JSON da service account do Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# Projeto e região do GCP (Vertex AI)
GCP_PROJECT_ID=meu-projeto-gcp
GCP_LOCATION=us-central1

# Modelo Gemini a utilizar
GEMINI_MODEL=gemini-2.5-pro

# Pastas de entrada/saída
PROMPTS_DIR=./prompts
GRAPH_SCHEMA_DIR=./graph-schema
OUTPUT_DIR=./output

# Neo4j (opcional — necessário apenas com --push)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=senha
