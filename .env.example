# Caminho para o JSON da service account do Google Cloud (obrigatório)
# O project_id é lido automaticamente deste arquivo.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# Scopes OAuth — opcional, padrão já inclui cloud-platform e generative-language
# GOOGLE_TOKEN_SCOPES=https://www.googleapis.com/auth/cloud-platform,https://www.googleapis.com/auth/generative-language

# Região do Vertex AI — opcional, padrão: us-central1
# GCP_LOCATION=us-central1

# Modelo Gemini — opcional, padrão: gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-pro

# Pastas — todos opcionais, os padrões já funcionam
PROMPTS_DIR=./prompts
GRAPH_SCHEMA_DIR=./graph-schema
OUTPUT_DIR=./output

# Neo4j — necessário apenas com o comando "push"
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=senha

# Confluence — necessário para o comando "confluence" / menu
CONFLUENCE_BASE_URL=https://sua-empresa.atlassian.net/wiki
CONFLUENCE_EMAIL=seu@email.com
CONFLUENCE_API_KEY=sua-api-key-do-confluence
# CONFLUENCE_OUTPUT_DIR=./output/confluence

# TLS — se o Confluence usar certificado de CA corporativa interna:
# Opção A (recomendado): apontar para o arquivo .pem da CA raiz da empresa
# NODE_EXTRA_CA_CERTS=/caminho/para/ca-corporativa.pem
# Opção B (rede interna segura): desabilitar verificação de certificado
# CONFLUENCE_TLS_SKIP_VERIFY=true
